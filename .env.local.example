LLM_PROVIDER=openai-compatible
OPENAI_COMPATIBLE_BASE_URL=http://your-openai-compatible-host/v1
OPENAI_COMPATIBLE_API_KEY=your_api_key
# Some OpenAI-compatible Claude gateways require temperature=1.
# Leave empty unless your gateway rejects lower temperatures.
OPENAI_COMPATIBLE_FORCE_TEMPERATURE=

# Native Anthropic provider alternative:
# LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_api_key
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_VERSION=2023-06-01

CLAUDE_RESEARCHER_MODEL=claude-opus-4-6
CLAUDE_RESEARCHER_FALLBACK_MODEL=claude-opus-4-6
CLAUDE_RESEARCHER_MAX_TOKENS=8192
ENABLE_PROMPT_CACHE=1

# Diagnostic scripts do not overwrite shell env from this file unless enabled.
OVERRIDE_ENV_FILE=
# Set to 1 if your OpenAI-compatible gateway supports /models and you want that check to fail hard.
STRICT_MODELS_CHECK=

# Archived AI-HQ fallback models; AI-MBTI no longer uses separate Agent A/B calls.
CLAUDE_AGENT_A_MODEL=claude-opus-4-6
CLAUDE_AGENT_B_MODEL=claude-opus-4-6

# Phase 7 feedback storage.
# If either value is absent, POST /api/feedback writes to .local-debug/feedback.
# NOTION_FEEDBACK_DATABASE_ID is the Notion data_source_id for the feedback table.
NOTION_API_KEY=
NOTION_FEEDBACK_DATABASE_ID=777147e1-3401-4f4b-98dc-bc14fce6a127
# Optional override if you keep the data source ID separate from the historical env name.
NOTION_FEEDBACK_DATA_SOURCE_ID=
# Optional override for the Notion API version used by fetch.
NOTION_VERSION=2026-03-11
