OPENAI_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_COMPATIBLE_API_KEY=your_api_key

QWEN_MODEL=qwen3.6-plus
QWEN_FALLBACK_MODEL=qwen3.6-plus
QWEN_MAX_TOKENS=8192
QWEN_CHAT_MAX_RETRIES=3

# Optional report-specific override. Leave empty to reuse QWEN_MODEL / QWEN_MAX_TOKENS.
QWEN_REPORT_MODEL=
QWEN_REPORT_MAX_TOKENS=

# Qwen/OpenAI-compatible gateway options.
OPENAI_COMPATIBLE_FORCE_TEMPERATURE=
# For hybrid-thinking Qwen models, the app auto-sends enable_thinking:false when the base URL
# contains dashscope.aliyuncs.com or dashscope-intl.aliyuncs.com (required for forced tool_choice).
# Set this to 1 only if you explicitly want to skip that behavior.
OPENAI_COMPATIBLE_ENABLE_THINKING=
OPENAI_COMPATIBLE_EXTRA_JSON=

# 0 = do not attach cache_control metadata to system prompt blocks; 1 = keep prompt cache hints.
ENABLE_PROMPT_CACHE=1

# Diagnostic scripts do not overwrite shell env from this file unless enabled.
OVERRIDE_ENV_FILE=
# Set to 1 if your OpenAI-compatible gateway supports /models and you want that check to fail hard.
STRICT_MODELS_CHECK=

# Phase 7 feedback storage.
# If either value is absent, POST /api/feedback writes to .local-debug/feedback.
# NOTION_FEEDBACK_DATABASE_ID is the Notion data_source_id for the feedback table.
NOTION_API_KEY=
NOTION_FEEDBACK_DATABASE_ID=777147e1-3401-4f4b-98dc-bc14fce6a127
# Optional override if you keep the data source ID separate from the historical env name.
NOTION_FEEDBACK_DATA_SOURCE_ID=
# Optional override for the Notion API version used by fetch.
NOTION_VERSION=2026-03-11
