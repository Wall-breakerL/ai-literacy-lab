# 复制为 .env.local 后按需填写。未配置时对话走 mock、评测走规则 Judge。

# 对话与评测共用（或仅对话）
# OPENAI_API_KEY=

# 可选：兼容 Azure / 第三方
# OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：对话用模型（默认 gpt-4o-mini）
# OPENAI_CHAT_MODEL=gpt-4o-mini

# 可选：评测 Judge 用模型（默认 gpt-4o）；可与对话不同
# OPENAI_JUDGE_MODEL=gpt-4o

# 可选：若希望 Judge 使用单独 key
# OPENAI_JUDGE_API_KEY=

# ---------- 使用 Minimax（OpenAI 兼容，示例）----------
# OPENAI_BASE_URL=https://api.minimaxi.com/v1
# OPENAI_API_KEY=你的_Minimax_Key
# OPENAI_CHAT_MODEL=MiniMax-M2.5
# OPENAI_JUDGE_MODEL=MiniMax-M2.5
